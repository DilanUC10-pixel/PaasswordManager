<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp">

        <TextView
            android:id="@+id/tvDetailTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Detalle de Cuenta"
            android:textSize="24sp"
            android:textStyle="bold"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/tvDetailName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Nombre: "
            android:textSize="18sp"
            android:layout_marginTop="24dp"
            app:layout_constraintTop_toBottomOf="@id/tvDetailTitle" />

        <TextView
            android:id="@+id/tvDetailCategory"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Categoría: "
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/tvDetailName" />

        <TextView
            android:id="@+id/tvDetailUsage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Uso: "
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/tvDetailCategory" />

        <TextView
            android:id="@+id/tvDetailUrl"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="URL: "
            android:layout_marginTop="8dp"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/tvDetailUsage" />

        <TextView
            android:id="@+id/tvDetailEmail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Email: "
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/tvDetailUrl" />

        <TextView
            android:id="@+id/tvDetailUsername"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Usuario: "
            android:layout_marginTop="8dp"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/tvDetailEmail" />

        <TextView
            android:id="@+id/tvDetailPassword"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Contraseña: ********"
            android:layout_marginTop="8dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvDetailUsername" />

        <Button
            android:id="@+id/btnShowPassword"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mostrar"
            android:layout_marginStart="16dp"
            style="?android:attr/borderlessButtonStyle"
            app:layout_constraintBottom_toBottomOf="@id/tvDetailPassword"
            app:layout_constraintStart_toEndOf="@id/tvDetailPassword"
            app:layout_constraintTop_toTopOf="@id/tvDetailPassword" />

        <TextView
            android:id="@+id/tvDetailPhone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Teléfono: "
            android:layout_marginTop="8dp"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/tvDetailPassword" />

        <TextView
            android:id="@+id/tvDetailAltEmail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Correo alterno: "
            android:layout_marginTop="8dp"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/tvDetailPhone" />

        <TextView
            android:id="@+id/tvDetailDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Fecha registro: "
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/tvDetailAltEmail" />

        <Button
            android:id="@+id/btnEditAccount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Editar"
            android:layout_marginTop="32dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvDetailDate" />

        <Button
            android:id="@+id/btnDeleteAccount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Eliminar"
            android:textColor="@android:color/holo_red_dark"
            android:layout_marginStart="16dp"
            style="?android:attr/borderlessButtonStyle"
            app:layout_constraintBottom_toBottomOf="@id/btnEditAccount"
            app:layout_constraintStart_toEndOf="@id/btnEditAccount"
            app:layout_constraintTop_toTopOf="@id/btnEditAccount" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
